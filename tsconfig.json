{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "alwaysStrict": true,
    "declaration": true,
    "declarationDir": "./types",
    "emitDeclarationOnly": true,
    "ignoreDeprecations": "6.0",
    "lib": [
      "ES2015"
    ],
    "module": "CommonJS",
    "moduleResolution": "node",
    "newLine": "lf",
    "pretty": true,
    "removeComments": false,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "ES2015",
    "types": [
      "node",
    ],
  },
  "exclude": [],
  "include": [
    "src",
  ],
}
