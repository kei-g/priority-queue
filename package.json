{
  "author": {
    "email": "km.8k6ce+npm@gmail.com",
    "name": "kei-g"
  },
  "bugs": {
    "url": "https://github.com/kei-g/priority-queue/issues"
  },
  "description": "Priority Queue",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.6.2",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.6.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "^6.0.3"
  },
  "homepage": "https://github.com/kei-g/priority-queue",
  "keywords": [
    "PriorityQueue"
  ],
  "license": "BSD-3-Clause",
  "main": "index.js",
  "name": "@kei-g/priority-queue",
  "overrides": {
    "c8": {
      "test-exclude": {
        "minimatch": "^10.2.5"
      },
      "yargs": "^18.0.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "github:kei-g/priority-queue",
  "scripts": {
    "build": "npm-run-all2 --parallel build:*",
    "build:bundle": "esbuild src/index.ts --bundle --charset=utf8 --format=cjs --minify --outfile=index.js --platform=node --target=ES2015",
    "build:tsc": "tsc",
    "clean": "node -e '[\"coverage\", \"index.d.ts\", \"index.js\", \"lib\"].forEach(name => fs.rmSync(name, { force: true, recursive: true }))'",
    "cover": "c8 node --test",
    "lint": "biome lint --write",
    "postpublish": "npm run clean",
    "postbuild:tsc": "mv types/src/index.d.ts types/src/lib/priority-queue.d.ts ./",
    "prebuild": "npm-run-all2 --parallel clean lint",
    "prepublishOnly": "npm run build",
    "test": "npm-run-all2 --parallel cover lint"
  },
  "types": "index.d.ts",
  "version": "1.1.9"
}
